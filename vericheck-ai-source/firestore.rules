rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, createdAt
    //
    // Collection: scans
    // Fields: uid, productName, brandName, isGenuine, confidence, estimatedPrice, image, timestamp, reasoning, anomalies, tips
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "bharathkumarangirekula@gmail.com" && request.auth.token.email_verified == true));
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 256;
    }

    function isValidScan(data) {
      return data.keys().hasAll(['uid', 'productName', 'isGenuine', 'confidence', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.productName is string && data.productName.size() < 256 &&
             data.isGenuine is bool &&
             data.confidence is number &&
             data.timestamp is int &&
             (!('reasoning' in data) || (data.reasoning is string && data.reasoning.size() < 5000)) &&
             (!('brandName' in data) || (data.brandName is string && data.brandName.size() < 256)) &&
             (!('manufactureDate' in data) || (data.manufactureDate is string && data.manufactureDate.size() < 100)) &&
             (!('manufacturePlace' in data) || (data.manufacturePlace is string && data.manufacturePlace.size() < 500)) &&
             (!('image' in data) || (data.image is string && data.image.size() < 2000000)); // 2MB limit for base64
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /scans/{scanId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidScan(request.resource.data);
      allow update, delete: if isDocOwner() || isAdmin();
    }
  }
}
